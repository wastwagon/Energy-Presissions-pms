# =============================================================================
# Energy Precision PMS – Environment Configuration
# =============================================================================
# Copy to .env and adjust for your environment (local dev or production).
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Leave empty to use local Postgres (docker-compose db service)
# Set to Render External URL for production or to test against Render DB locally
# DATABASE_URL=postgresql://user:password@host.oregon-postgres.render.com/dbname?sslmode=require

# Used when DATABASE_URL is not set (local docker-compose)
POSTGRES_USER=energy_pms
POSTGRES_PASSWORD=changeme
POSTGRES_DB=energy_pms
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Startup seeding is disabled by default for safety in production.
# Set AUTO_SEED=true only for first-time environment bootstrap.
# AUTO_SEED=false
# Optional seed overrides:
# DEFAULT_ADMIN_EMAIL=admin@energyprecisions.com
# DEFAULT_ADMIN_PASSWORD=change-me
# FORCE_RESET_ADMIN_PASSWORD=false
# DEFAULT_WEBSITE_ADMIN_EMAIL=webadmin@energyprecisions.com
# DEFAULT_WEBSITE_ADMIN_PASSWORD=change-me
# FORCE_RESET_WEBSITE_ADMIN_PASSWORD=false

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# API base URL – use http://localhost:8000 for local dev (browser calls backend)
REACT_APP_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# CORS (optional)
# -----------------------------------------------------------------------------
# Comma-separated origins. Leave empty to use defaults (localhost + energyprecisions.com).
# CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:5173

# -----------------------------------------------------------------------------
# Company
# -----------------------------------------------------------------------------
COMPANY_NAME=Energy Precisions
COMPANY_ADDRESS=Haatso - Ecomog
COMPANY_PHONE=+233 533 611 611
COMPANY_EMAIL=info@energyprecisions.com

# -----------------------------------------------------------------------------
# Email (optional – for order notifications, etc.)
# -----------------------------------------------------------------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=

# -----------------------------------------------------------------------------
# Paystack (e-commerce checkout — set on production backend only, never commit)
# -----------------------------------------------------------------------------
# Use your live keys from Paystack Dashboard → Settings → API Keys & Webhooks.
# Backend reads these; checkout uses server-side initialize + redirect (no pk in browser).
# PAYSTACK_SECRET_KEY=sk_live_...
# PAYSTACK_PUBLIC_KEY=pk_live_...
# FRONTEND_URL=https://energyprecisions.com
#
# Webhook URL (Paystack dashboard): https://<your-backend-host>/api/payments/paystack/webhook
# Example: https://energy-pms-backend-1b7h.onrender.com/api/payments/paystack/webhook
